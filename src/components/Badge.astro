---
interface Props {
  text?: string;
  href?: string;
  accent?: boolean;
  i18n?: string;
}

const {text, href, accent = false, i18n} = Astro.props;
const baseClass = `inline-flex items-center gap-1.5 px-2 py-1 text-xs rounded-lg transition-colors ${accent ? 'bg-app-accent/15 text-app-accent font-medium' : 'bg-app-surface-dark text-app-text-secondary'}`;
const hoverClass = href ? ' hover:text-app-text-primary' : '';
---

{href ? (
<a href={href} target="_blank" rel="noopener" class={baseClass + hoverClass}>
    <slot/>
  {i18n ? <span data-i18n={i18n}></span> : text}
</a>
  ) : (
<span class={baseClass}>
        <slot/>
  {i18n ? <span data-i18n={i18n}></span> : text}
    </span>
  )}
