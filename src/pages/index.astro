---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {Blocks, Smartphone, Code2, ExternalLink, ImageOff, Bot, KeyRound, Lock} from 'lucide-astro';
import Badge from '@/components/Badge.astro';
import {projects} from '@/data/projects';

const iconMap = {Blocks, Code2, Smartphone, Bot, KeyRound};
const badgeIconMap = {ExternalLink, Lock};
---

<BaseLayout title="jahirtrap — Developer">
    <div class="space-y-8">
        <!-- Profile -->
        <section class="flex flex-col items-center text-center gap-3 pt-4">
            <div id="avatar-placeholder"
                 class="w-28 h-28 rounded-full ring-2 ring-app-border bg-app-surface-dark flex items-center justify-center">
                <ImageOff class="w-8 h-8 text-app-text-secondary"/>
            </div>
            <img id="avatar" src="https://github.com/jahirxtrap.png" alt="jahirtrap"
                 class="w-28 h-28 rounded-full ring-2 ring-app-border hidden"
                 onload="this.classList.remove('hidden');document.getElementById('avatar-placeholder').classList.add('hidden')"/>
            <div>
                <h1 class="text-3xl font-bold text-app-text-primary" id="profile-name">jahirtrap</h1>
                <p class="text-app-text-secondary mt-1" id="profile-bio">...</p>
            </div>
            <div class="flex gap-3">
                <Badge href="https://github.com/jahirxtrap" text="GitHub">
                    <ExternalLink class="w-3 h-3"/>
                </Badge>
            </div>
        </section>

        <!-- Projects -->
        <section>
            <h2 class="text-xl font-bold text-app-text-primary mb-6" data-i18n="home.projects"></h2>

            <div class="grid gap-4 sm:grid-cols-2">
                {projects.map(project => {
                  const Icon = iconMap[project.icon];
                  const isExternal = project.href?.startsWith('http');
                  const linkAttrs = project.href ? {
                    href: project.href,
                    ...(isExternal ? {target: '_blank', rel: 'noopener'} : {}),
                  } : null;
                  const cardClass = 'p-6 rounded-xl border border-app-border bg-app-surface' +
                    (project.href ? ' group hover:bg-app-surface-dark transition-colors' : '');
                  const titleAttrs = project.titleIsKey ? {'data-i18n': project.title} : {};
                  const titleText = project.titleIsKey ? '' : project.title;
                  return linkAttrs ? (
                          <a {...linkAttrs} class={cardClass}>
                              <div class="flex items-center gap-3 mb-2">
                                  <Icon class="w-6 h-6 text-app-accent"/>
                                  <h3 class="text-lg font-semibold text-app-text-primary"
                                      {...titleAttrs}>{titleText}</h3>
                              </div>
                              <p class="text-sm text-app-text-secondary" data-i18n={project.descKey}></p>
                              {project.ctaKey && (
                                      <span class="inline-block mt-3 text-sm text-app-accent group-hover:underline"
                                            data-i18n={project.ctaKey}></span>
                              )}
                          </a>
                  ) : (
                          <div class={cardClass}>
                              <div class="flex items-center gap-3 mb-2">
                                  <Icon class="w-6 h-6 text-app-accent"/>
                                  <h3 class="text-lg font-semibold text-app-text-primary"
                                      {...titleAttrs}>{titleText}</h3>
                              </div>
                              <p class="text-sm text-app-text-secondary mb-3" data-i18n={project.descKey}></p>
                              {project.badges && project.badges.length > 0 && (
                                      <div class="flex flex-wrap gap-2">
                                        {project.badges.map(badge => {
                                          const BadgeIcon = badge.icon ? badgeIconMap[badge.icon] : null;
                                          return (
                                                  <Badge href={badge.href} i18n={badge.textKey} accent={badge.accent}>
                                                    {BadgeIcon && <BadgeIcon class="w-3 h-3"/>}
                                                  </Badge>
                                          );
                                        })}
                                      </div>
                              )}
                          </div>
                  );
                })}
            </div>
        </section>
    </div>

    <script>
      import {fetchGitHubUser} from '@/utils/api';

      async function loadProfile() {
        const user = await fetchGitHubUser('jahirxtrap');
        if (user) {
          const nameEl = document.getElementById('profile-name');
          const bioEl = document.getElementById('profile-bio');
          if (nameEl && user.name) nameEl.textContent = user.name;
          if (bioEl && user.bio) bioEl.textContent = user.bio;
        }
      }

      loadProfile();
    </script>
</BaseLayout>
