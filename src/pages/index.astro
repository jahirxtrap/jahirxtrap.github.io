---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {Blocks, Smartphone, Code2, ExternalLink, ImageOff} from 'lucide-astro';
import Badge from '@/components/Badge.astro';
---

<BaseLayout title="jahirtrap — Developer">
    <div class="space-y-8">
        <!-- Profile -->
        <section class="flex flex-col items-center text-center gap-3 pt-4">
            <div id="avatar-placeholder"
                 class="w-28 h-28 rounded-full ring-2 ring-app-border bg-app-surface-dark flex items-center justify-center">
                <ImageOff class="w-8 h-8 text-app-text-secondary"/>
            </div>
            <img id="avatar" src="https://github.com/jahirxtrap.png" alt="jahirtrap"
                 class="w-28 h-28 rounded-full ring-2 ring-app-border hidden"
                 onload="this.classList.remove('hidden');document.getElementById('avatar-placeholder').classList.add('hidden')"/>
            <div>
                <h1 class="text-3xl font-bold text-app-text-primary" id="profile-name">jahirtrap</h1>
                <p class="text-app-text-secondary mt-1" id="profile-bio">...</p>
            </div>
            <div class="flex gap-3">
                <Badge href="https://github.com/jahirxtrap" text="GitHub">
                    <ExternalLink class="w-3 h-3"/>
                </Badge>
            </div>
        </section>

        <!-- Projects -->
        <section>
            <h2 class="text-xl font-bold text-app-text-primary mb-6" data-i18n="home.projects"></h2>

            <div class="grid gap-4 sm:grid-cols-2">
                <a href="/minecraft-mods"
                   class="group p-6 rounded-xl border border-app-border bg-app-surface hover:bg-app-surface-dark transition-colors">
                    <div class="flex items-center gap-3 mb-2">
                        <Blocks class="w-6 h-6 text-app-accent"/>
                        <h3 class="text-lg font-semibold text-app-text-primary" data-i18n="home.minecraft"></h3>
                    </div>
                    <p class="text-sm text-app-text-secondary" data-i18n="home.minecraft_desc"></p>
                    <span class="inline-block mt-3 text-sm text-app-accent group-hover:underline"
                          data-i18n="home.view_all"></span>
                </a>

                <a href="/maven-libraries"
                   class="group p-6 rounded-xl border border-app-border bg-app-surface hover:bg-app-surface-dark transition-colors">
                    <div class="flex items-center gap-3 mb-2">
                        <Code2 class="w-6 h-6 text-app-accent"/>
                        <h3 class="text-lg font-semibold text-app-text-primary" data-i18n="home.libraries"></h3>
                    </div>
                    <p class="text-sm text-app-text-secondary" data-i18n="home.libraries_desc"></p>
                    <span class="inline-block mt-3 text-sm text-app-accent group-hover:underline"
                          data-i18n="home.view_all"></span>
                </a>

                <a href="https://play.google.com/store/apps/developer?id=jahirtrap" target="_blank" rel="noopener"
                   class="group p-6 rounded-xl border border-app-border bg-app-surface hover:bg-app-surface-dark transition-colors">
                    <div class="flex items-center gap-3 mb-2">
                        <Smartphone class="w-6 h-6 text-app-accent"/>
                        <h3 class="text-lg font-semibold text-app-text-primary" data-i18n="home.android"></h3>
                    </div>
                    <p class="text-sm text-app-text-secondary" data-i18n="home.android_desc"></p>
                    <span class="inline-block mt-3 text-sm text-app-accent group-hover:underline"
                          data-i18n="home.play_store"></span>
                </a>
            </div>
        </section>
    </div>

    <script>
      import {fetchGitHubUser} from '@/utils/api';

      async function loadProfile() {
        const user = await fetchGitHubUser('jahirxtrap');
        if (user) {
          const nameEl = document.getElementById('profile-name');
          const bioEl = document.getElementById('profile-bio');
          if (nameEl && user.name) nameEl.textContent = user.name;
          if (bioEl && user.bio) bioEl.textContent = user.bio;
        }
      }

      loadProfile();
    </script>
</BaseLayout>
