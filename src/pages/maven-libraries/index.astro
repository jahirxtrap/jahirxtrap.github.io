---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {ChevronRight, ChevronDown, ExternalLink, ImageOff} from 'lucide-astro';
import Badge from '@/components/Badge.astro';

const libraries = [
  {
    id: 'configlibtxf',
    repo: 'jahirxtrap/configlibtxf',
    mavenGroup: 'io.github.jahirxtrap',
    mavenArtifact: 'configlibtxf',
    logoPath: 'common/src/main/resources/logo.png',
    branch: 'master',
    wikiPages: ['Home', 'Configuration', 'Screen-&-Server-Sync'],
  },
];

const mavenProfileUrl = 'https://central.sonatype.com/namespace/io.github.jahirxtrap';

function formatPageName(page: string): string {
  return page.replace(/-/g, ' ').replace(/&amp;/g, '&').replace(/&/g, '&');
}
---

<BaseLayout title="jahirtrap — Maven Libraries">
    <div class="space-y-6">
        <div class="text-center">
            <h1 class="text-3xl font-bold text-app-text-primary" data-i18n="libraries.title"></h1>
            <p class="text-app-text-secondary mt-2" data-i18n="libraries.subtitle"></p>
            <div class="mt-3">
                <Badge href={mavenProfileUrl} i18n="libraries.profile">
                    <ExternalLink class="w-3 h-3"/>
                </Badge>
            </div>
        </div>

      {libraries.map((lib) => (
              <div class="rounded-xl border border-app-border bg-app-surface overflow-hidden p-5" data-lib={lib.id}>
                  <!-- Header -->
                  <div class="flex items-center gap-4">
                      <div class="w-14 h-14 rounded-xl bg-app-surface-dark flex items-center justify-center flex-shrink-0"
                           data-lib-logo={lib.id}>
                          <ImageOff class="w-6 h-6 text-app-text-secondary"/>
                      </div>
                    {lib.logoPath && (
                            <img src={`https://raw.githubusercontent.com/${lib.repo}/${lib.branch}/${lib.logoPath}`}
                                 alt={lib.id} class="w-14 h-14 rounded-xl hidden flex-shrink-0" data-lib-img={lib.id}
                                 onload={`this.classList.remove('hidden');document.querySelector('[data-lib-logo="${lib.id}"]').classList.add('hidden')`}/>
                    )}
                      <div class="flex-1">
                          <h2 class="text-xl font-bold text-app-text-primary" data-repo-name={lib.repo}></h2>
                          <p class="text-sm text-app-text-secondary mt-1" data-repo-desc={lib.repo}></p>
                      </div>
                  </div>

                  <!-- Stats -->
                  <div class="flex flex-wrap gap-2 empty:hidden [&:not(:empty)]:mt-3" data-maven-stats={lib.id}></div>

                  <!-- Links -->
                  <div class="mt-3 flex flex-wrap gap-2">
                      <Badge href={`https://central.sonatype.com/artifact/${lib.mavenGroup}/${lib.mavenArtifact}`}
                             i18n="libraries.maven_central">
                          <ExternalLink class="w-3 h-3"/>
                      </Badge>
                      <Badge href={`https://github.com/${lib.repo}`} i18n="libraries.source_code">
                          <ExternalLink class="w-3 h-3"/>
                      </Badge>
                    {lib.wikiPages.length > 0 && (
                            <Badge href={`https://github.com/${lib.repo}/wiki`} text="Wiki">
                                <ExternalLink class="w-3 h-3"/>
                            </Badge>
                    )}
                  </div>

                  <!-- Docs toggle -->
                {lib.wikiPages.length > 0 && (
                        <div class="mt-3">
                            <button class="docs-toggle w-full flex items-center justify-between pt-3 text-sm font-semibold text-app-text-primary cursor-pointer border-t border-app-border"
                                    data-target={`docs-${lib.id}`}>
                                <span data-i18n="libraries.documentation"></span>
                                <span class="text-app-text-secondary">
                                <span class="docs-icon-right"><ChevronRight class="w-4 h-4"/></span>
                                <span class="docs-icon-down hidden"><ChevronDown class="w-4 h-4"/></span>
                            </span>
                            </button>

                            <div id={`docs-${lib.id}`} class="hidden">
                                <div class="flex gap-4 mt-3">
                                    <nav class="flex-shrink-0 w-48 space-y-1">
                                      {lib.wikiPages.map((page, i) => (
                                              <button class="wiki-nav w-full text-left px-3 py-2 text-sm rounded-lg transition-colors cursor-pointer"
                                                      data-lib={lib.id} data-page={page}
                                                      data-active={i === 0 ? 'true' : 'false'}>
                                                {formatPageName(page)}
                                              </button>
                                      ))}
                                    </nav>

                                    <div class="flex-1 min-w-0">
                                      {lib.wikiPages.map((page, i) => (
                                              <div class={`wiki-content ${i === 0 ? '' : 'hidden'}`}
                                                   data-lib={lib.id} data-page={page}>
                                                  <p class="text-sm text-app-text-secondary">...</p>
                                              </div>
                                      ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                )}
              </div>
      ))}
    </div>

    <script define:vars={{libraries}}>
      window.__libraries = libraries;
    </script>

    <script>
      import {fetchGitHubRepo, fetchGitHubRawFile, fetchMavenInfo} from '@/utils/api';
      import {getLang, t, onLangChange} from '@/utils/i18n';
      import {renderMarkdown, addCopyButtons, markdownStyles} from '@/utils/markdown';
      import {createBadge} from '@/utils/badge';

      interface LibConfig {
        id: string;
        repo: string;
        mavenGroup: string;
        mavenArtifact: string;
        branch: string;
        wikiPages: string[];
      }

      const libs: LibConfig[] = (window as any).__libraries;
      const lang = getLang();

      // Load data for each library
      for (const lib of libs) {
        const [owner, repoName] = lib.repo.split('/');

        // GitHub repo info
        fetchGitHubRepo(owner, repoName).then(repo => {
          if (!repo) return;
          const nameEl = document.querySelector(`[data-repo-name="${lib.repo}"]`);
          const descEl = document.querySelector(`[data-repo-desc="${lib.repo}"]`);
          if (nameEl) nameEl.textContent = repo.name;
          if (descEl) descEl.textContent = repo.description || '';
        });

        // Maven stats
        fetchMavenInfo(lib.mavenGroup, lib.mavenArtifact).then(info => {
          if (!info) return;

          const container = document.querySelector(`[data-maven-stats="${lib.id}"]`);
          if (!container) return;
          onLangChange(l => {
            container.textContent = '';
            container.appendChild(createBadge(`${t(l, 'libraries.latest')}: ${info.latestVersion}`, {accent: true}));
            container.appendChild(createBadge(`${info.totalVersions} ${t(l, 'libraries.versions')}`));
            container.appendChild(createBadge(`${t(l, 'libraries.license')}: ${info.license}`));
          });
        });

        // Wiki pages
        for (const page of lib.wikiPages) {
          fetchGitHubRawFile(owner, repoName, lib.branch, `wiki/${page}.md`).then(async (md) => {
            if (!md) return;
            const cleanHtml = await renderMarkdown(md);

            const container = document.querySelector(`.wiki-content[data-lib="${lib.id}"][data-page="${page}"]`);
            if (!container) return;

            container.textContent = '';
            const content = document.createElement('div');
            content.className = markdownStyles;
            content.innerHTML = cleanHtml;
            container.appendChild(content);
            addCopyButtons(content);
          });
        }
      }

      // Docs toggle
      document.querySelectorAll('.docs-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = (btn as HTMLElement).dataset.target!;
          const body = document.getElementById(targetId)!;
          const isHidden = body.classList.contains('hidden');
          body.classList.toggle('hidden');
          btn.querySelector('.docs-icon-right')!.classList.toggle('hidden', isHidden);
          btn.querySelector('.docs-icon-down')!.classList.toggle('hidden', !isHidden);
        });
      });

      // Wiki nav
      document.querySelectorAll('.wiki-nav').forEach(btn => {
        btn.addEventListener('click', () => {
          const el = btn as HTMLElement;
          const libId = el.dataset.lib!;
          const page = el.dataset.page!;

          document.querySelectorAll(`.wiki-nav[data-lib="${libId}"]`).forEach(b => {
            const isActive = (b as HTMLElement).dataset.page === page;
            (b as HTMLElement).dataset.active = isActive ? 'true' : 'false';
            b.className = `wiki-nav w-full text-left px-3 py-2 text-sm rounded-lg transition-colors cursor-pointer ${isActive ? 'bg-app-accent text-app-text-inverse' : 'text-app-text-secondary hover:text-app-text-primary hover:bg-app-surface-dark'}`;
          });

          document.querySelectorAll(`.wiki-content[data-lib="${libId}"]`).forEach(c => {
            c.classList.toggle('hidden', (c as HTMLElement).dataset.page !== page);
          });
        });
      });

      // Init sidebar styles
      document.querySelectorAll('.wiki-nav').forEach(btn => {
        const el = btn as HTMLElement;
        const isActive = el.dataset.active === 'true';
        el.className = `wiki-nav w-full text-left px-3 py-2 text-sm rounded-lg transition-colors cursor-pointer ${isActive ? 'bg-app-accent text-app-text-inverse' : 'text-app-text-secondary hover:text-app-text-primary hover:bg-app-surface-dark'}`;
      });
    </script>
</BaseLayout>
