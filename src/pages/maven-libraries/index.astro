---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {ExternalLink, ImageOff} from 'lucide-astro';
import Badge from '@/components/Badge.astro';
import {libraries, mavenProfileUrl} from '@/data/maven-libraries';
---

<BaseLayout title="jahirtrap — Maven Libraries">
    <div class="space-y-6">
        <div class="text-center">
            <h1 class="text-3xl font-bold text-app-text-primary" data-i18n="libraries.title"></h1>
            <p class="text-app-text-secondary mt-2" data-i18n="libraries.subtitle"></p>
            <div class="flex flex-wrap items-center justify-center gap-2 mt-3">
                <Badge href={mavenProfileUrl} i18n="libraries.profile">
                    <ExternalLink class="w-3 h-3"/>
                </Badge>
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            {libraries.map(lib => (
                    <a href={`/maven-libraries/${lib.id}`}
                       class="group p-4 rounded-xl border border-app-border bg-app-surface hover:bg-app-surface-dark transition-colors"
                       data-lib={lib.id}>
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-12 h-12 rounded-lg bg-app-surface-dark flex items-center justify-center flex-shrink-0"
                                 data-lib-logo={lib.id}>
                                <ImageOff class="w-5 h-5 text-app-text-secondary"/>
                            </div>
                            {lib.logoPath && (
                                    <img src={`https://raw.githubusercontent.com/${lib.repo}/${lib.branch}/${lib.logoPath}`}
                                         alt={lib.id} class="w-12 h-12 rounded-lg hidden flex-shrink-0"
                                         data-lib-img={lib.id}
                                         onload={`this.classList.remove('hidden');document.querySelector('[data-lib-logo="${lib.id}"]').classList.add('hidden')`}/>
                            )}
                            <div class="min-w-0 flex-1">
                                <h3 class="font-semibold text-app-text-primary truncate"
                                    data-repo-name={lib.repo}>{lib.id}</h3>
                                <p class="text-sm text-app-text-secondary mt-1 line-clamp-2"
                                   data-repo-desc={lib.repo}></p>
                            </div>
                        </div>

                        <div class="flex flex-wrap gap-1.5" data-maven-stats={lib.id}></div>
                    </a>
            ))}
        </div>
    </div>

    <script define:vars={{libraries}}>
      window.__libraries = libraries;
    </script>

    <script>
      import {fetchGitHubRepo, fetchMavenInfo} from '@/utils/api';
      import {getLang, t, onLangChange} from '@/utils/i18n';
      import {createBadge} from '@/utils/badge';

      const libs: any[] = (window as any).__libraries;

      for (const lib of libs) {
        const [owner, repoName] = lib.repo.split('/');

        fetchGitHubRepo(owner, repoName).then(repo => {
          if (!repo) return;
          const nameEl = document.querySelector(`[data-repo-name="${lib.repo}"]`);
          const descEl = document.querySelector(`[data-repo-desc="${lib.repo}"]`);
          if (nameEl) nameEl.textContent = repo.name;
          if (descEl) descEl.textContent = repo.description || '';
        });

        fetchMavenInfo(lib.mavenGroup, lib.mavenArtifact).then(info => {
          if (!info) return;
          const container = document.querySelector(`[data-maven-stats="${lib.id}"]`);
          if (!container) return;
          onLangChange(l => {
            container.textContent = '';
            container.appendChild(createBadge(`${t(l, 'libraries.latest')}: ${info.latestVersion}`, {accent: true}));
            container.appendChild(createBadge(`${info.totalVersions} ${t(l, 'libraries.versions')}`));
            container.appendChild(createBadge(`${t(l, 'libraries.license')}: ${info.license}`));
          });
        });
      }
    </script>
</BaseLayout>
