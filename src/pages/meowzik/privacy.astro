---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy — Meowzik Player">
    <div class="max-w-3xl mx-auto space-y-6">
        <header>
            <p class="text-sm text-app-text-secondary">Last updated: September 6, 2025</p>
            <h1 class="text-2xl font-bold text-app-text-primary mt-2">Privacy Policy — Meowzik Player</h1>
        </header>

        <div class="p-6 rounded-xl border border-app-border bg-app-surface space-y-6">
            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">1. Controller & Contact</h2>
                <p class="text-sm text-app-text-secondary mt-1">
                    Controller: <strong class="text-app-text-primary">jahirtrap</strong><br/>
                    Support email: <a href="mailto:help.jahirtrap@outlook.com" class="text-app-accent hover:underline">help.jahirtrap@outlook.com</a>
                </p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">2. Scope</h2>
                <p class="text-sm text-app-text-secondary mt-1">This policy applies to the mobile application "Meowzik
                    Player" (the "App").</p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">3. Data We Do Not Collect</h2>
                <p class="text-sm text-app-text-secondary mt-1">
                    The App <strong class="text-app-text-primary">does not</strong> collect, share, or transmit personal
                    data to our servers or to third parties.
                    It includes no advertising, user accounts, or in-app purchases.
                </p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">4. Permissions & How It Works</h2>
                <p class="text-sm text-app-text-secondary mt-1">
                    To play audio stored on your device, the App may request system permissions (for example, access to
                    your audio files
                    or media library). Any information accessed via these permissions is processed <strong
                        class="text-app-text-primary">only on your device</strong>
                    and is <strong class="text-app-text-primary">not</strong> sent to servers.
                </p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">5. Third-Party Services</h2>
                <p class="text-sm text-app-text-secondary mt-1">The App <strong class="text-app-text-primary">does not
                    integrate</strong> third-party SDKs for advertising, analytics, or tracking.</p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">6. Children</h2>
                <p class="text-sm text-app-text-secondary mt-1">The App is designed for a general audience. We do not
                    collect personal data from children.</p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">7. Security & Retention</h2>
                <p class="text-sm text-app-text-secondary mt-1">
                    We do not store personal data on servers. If cloud features are introduced in the future, this
                    policy will be
                    updated before such features are enabled.
                </p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">8. Your Rights & Contact</h2>
                <p class="text-sm text-app-text-secondary mt-1">
                    For any questions or requests regarding this policy, contact us at
                    <a href="mailto:help.jahirtrap@outlook.com" class="text-app-accent hover:underline">help.jahirtrap@outlook.com</a>.
                </p>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-app-text-primary">9. Changes to This Policy</h2>
                <p class="text-sm text-app-text-secondary mt-1">
                    We may update this policy to reflect changes to the App or legal requirements. We will publish the
                    current version
                    at this same URL and indicate the "Last updated" date above.
                </p>
            </section>
        </div>
    </div>
</BaseLayout>
